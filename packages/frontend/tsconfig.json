{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "declaration": false,
    "sourceMap": true,
    "composite": false,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@agentic-dev/shared": ["../shared/src/index.ts"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "references": []
}
