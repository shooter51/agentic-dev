# Core
PORT=3001
ANTHROPIC_API_KEY=your_anthropic_api_key_here
DB_PATH=data/agentic-dev.db
HELP_MODEL_ID=claude-sonnet-4-6

# Auth — JWT signing keys (JSON object: { "kid": "base64-encoded-key->=32-bytes" })
AUTH_JWT_KEYS={"key1":"base64-encoded-secret-key-at-least-32-bytes"}
AUTH_CURRENT_KID=key1
AUTH_ISSUER=agentic-dev
AUTH_AUDIENCE_ACCESS=agentic-dev-api
AUTH_AUDIENCE_REFRESH=agentic-dev-refresh
AUTH_ACCESS_TTL_SECONDS=900
AUTH_REFRESH_TTL_SECONDS=1209600
AUTH_CLOCK_SKEW_SECONDS=30
AUTH_LOGIN_RATE_MAX=5
AUTH_LOGIN_RATE_WINDOW_SECONDS=900

# Auth — Operator user (seeded at boot)
# Generate hash with: npm run auth:hash-password -- <password>
OPERATOR_EMAIL=admin@example.com
OPERATOR_PASSWORD_HASH=your_argon2id_hash_here
