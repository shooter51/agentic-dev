{
  "name": "@agentic-dev/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "auth:hash-password": "tsx src/auth/cli/hash-password.ts"
  },
  "dependencies": {
    "@agentic-dev/shared": "*",
    "@anthropic-ai/sdk": "^0.37.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "argon2": "^0.44.0",
    "better-sqlite3": "^9.4.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.39.0",
    "fastify": "^5.2.1",
    "gray-matter": "^4.0.3",
    "jose": "^6.2.2",
    "shell-quote": "^1.8.1",
    "ulid": "^2.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^22.0.0",
    "@types/shell-quote": "^1.7.5",
    "@vitest/coverage-v8": "^4.1.5",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  }
}
