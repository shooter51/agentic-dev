ANTHROPIC_API_KEY=your_anthropic_api_key_here
DB_PATH=data/agentic-dev.db
PORT=3001
HELP_MODEL_ID=claude-sonnet-4-6

# ── JWT Authentication ─────────────────────────────────────────────────────────
# AUTH_JWT_KEYS: JSON object mapping key-IDs to base64-encoded secrets (≥32 bytes each).
# Generate a key: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Multiple keys are supported for zero-downtime rotation (all listed keys can verify;
# only AUTH_CURRENT_KID is used for signing new tokens).
AUTH_JWT_KEYS={"v1":"<base64-encoded-256-bit-secret>"}

# AUTH_CURRENT_KID: The key ID used to sign new access and refresh tokens.
# Must be present as a key in AUTH_JWT_KEYS.
AUTH_CURRENT_KID=v1

# ── Operator seed ──────────────────────────────────────────────────────────────
# Seeded once at boot when no users exist. Generate hash: npm run auth:hash-password
OPERATOR_EMAIL=operator@example.com
OPERATOR_PASSWORD_HASH=<argon2id-hash-of-operator-password>

# ── Optional auth tuning (safe to omit; shown here for reference) ──────────────
# AUTH_ISSUER=agentic-dev
# AUTH_AUDIENCE_ACCESS=agentic-dev-api
# AUTH_AUDIENCE_REFRESH=agentic-dev-refresh
# AUTH_ACCESS_TTL_SECONDS=900          # 15 minutes
# AUTH_REFRESH_TTL_SECONDS=1209600     # 14 days
# AUTH_CLOCK_SKEW_SECONDS=30
# AUTH_LOGIN_RATE_MAX=5
# AUTH_LOGIN_RATE_WINDOW_SECONDS=900
